{
  "prediction_granularity": "one_row_per_inverter_per_day",
  "history_days": 30,
  "label_window_days": 7,
  "label_rule": "failure_if_future_shutdown_minutes>=60",
  "required_features": [
    "power_mean_30d",
    "power_std_30d",
    "power_zero_ratio_30d",
    "power_trend_30d",
    "uptime_ratio_30d",
    "shutdown_events_30d",
    "shutdown_minutes_30d",
    "temp_mean_30d",
    "temp_std_30d",
    "vline_std_mean_30d",
    "ambient_temp_mean_30d"
  ],
  "types": {
    "power_mean_30d": "float",
    "power_std_30d": "float",
    "power_zero_ratio_30d": "float",
    "power_trend_30d": "float",
    "uptime_ratio_30d": "float",
    "shutdown_events_30d": "int",
    "shutdown_minutes_30d": "int",
    "temp_mean_30d": "float",
    "temp_std_30d": "float",
    "vline_std_mean_30d": "float",
    "ambient_temp_mean_30d": "float"
  },
  "missing_value_rule": "impute_median"
}